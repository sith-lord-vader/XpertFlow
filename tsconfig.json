{
  "compilerOptions": {
    /*
     * ESNext modules are kept so the bundler can statically analyze imports
     * and produce a single file that doesn't contain any import/export
     * statements.  We also turn on `noEmit` so that `tsc` can be used purely
     * for type‑checking (via `npm run typecheck`) while the actual output is
     * generated by a bundler (esbuild, added below).
     */
    "target": "es2020",
    "module": "esnext",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "allowJs": false,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["chrome"]
  },
  "include": ["src"]
}
