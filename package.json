{
  "name": "omnibox-best-url",
  "version": "1.0.0",
  "description": "Chrome extension providing omnibox suggestions and best URL handling",
  "main": "dist/background.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "esbuild src/background.ts --bundle --outfile=dist/background.js --platform=browser --target=es2020 --sourcemap",
    "build": "npm run typecheck && npm run bundle",
    "watch": "esbuild src/background.ts --bundle --outfile=dist/background.js --platform=browser --target=es2020 --sourcemap --watch",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.238",
    "typescript": "^5.2.2",
    "esbuild": "^0.27.3",
    "rimraf": "^5.0.0"
  }
}
